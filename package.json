{
  "name": "module-bundle-chunk",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "build": "bun run --parallel 'build:*'",
    "inspect": "bun run --parallel 'inspect:*'",
    "build:webpack-default": "webpack build --config webpack.default.config.js --mode production",
    "inspect:webpack-default": "bun run build:webpack-default -- --analyze",
    "build:webpack-custom": "webpack build --config webpack.custom.config.js --mode production",
    "inspect:webpack-custom": "bun run build:webpack-custom -- --analyze",
    "build:vite-default": "bun run ./node_modules/vite/bin/vite.js --config vite.default.config.js build",
    "inspect:vite-default": "INSPECT=true bun run build:vite-default",
    "build:vite-custom": "bun run ./node_modules/vite/bin/vite.js --config vite.custom.config.js build",
    "inspect:vite-custom": "INSPECT=true bun run build:vite-custom",
    "build:vite7-default": "bun run ./node_modules/vite7/bin/vite.js --config vite7.default.config.js build",
    "inspect:vite7-default": "INSPECT=true bun run build:vite7-default && bun run .vite-inspect/vite7-default/stats.html",
    "build:vite7-custom": "bun run ./node_modules/vite7/bin/vite.js --config vite7.custom.config.js build",
    "inspect:vite7-custom": "INSPECT=true bun run build:vite7-custom && bun run .vite-inspect/vite7-custom/stats.html"
  },
  "devDependencies": {
    "@vitejs/devtools": "^0.1.15",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-sfc": "^3.5.33",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.10",
    "vite-plugin-inspect": "^12.0.0-beta.1",
    "vite7": "npm:vite@^7.3.2",
    "vue-loader": "^17.4.2",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "element-plus": "^2.13.7",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  }
}
